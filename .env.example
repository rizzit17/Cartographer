# =============================================================================
# Cartographer — Environment Variables Template
# Copy this file to .env and fill in your values.
# Never commit .env to source control.
# =============================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
APP_NAME=Cartographer
APP_ENV=development                  # development | production | test
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_WORKERS=1                        # uvicorn worker count (use 1 in dev)
SECRET_KEY=change-me-to-a-long-random-secret-key-at-least-32-chars

# ---------------------------------------------------------------------------
# Database (PostgreSQL + pgvector)
# ---------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=cartographer
POSTGRES_USER=cartographer
POSTGRES_PASSWORD=cartographer_secret
# Constructed automatically from above; override here if needed:
# DATABASE_URL=postgresql+asyncpg://cartographer:cartographer_secret@localhost:5432/cartographer

# Alembic uses sync driver for migrations
# ALEMBIC_DATABASE_URL=postgresql+psycopg2://cartographer:cartographer_secret@localhost:5432/cartographer

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=                      # Leave blank for no auth
# REDIS_URL=redis://localhost:6379/0

# ---------------------------------------------------------------------------
# JWT Authentication
# ---------------------------------------------------------------------------
JWT_SECRET_KEY=change-me-to-another-long-random-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ---------------------------------------------------------------------------
# GitHub OAuth (plug-in later; leave blank to disable)
# ---------------------------------------------------------------------------
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:8000/api/v1/auth/github/callback
GITHUB_OAUTH_ENABLED=false

# ---------------------------------------------------------------------------
# LLM Provider Configuration
# ---------------------------------------------------------------------------
# Default provider: anthropic | openai | ollama
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-5           # Model name for the active provider

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_BASE_URL=https://api.anthropic.com

# OpenAI / OpenAI-compatible
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_ORG_ID=                       # Optional

# Ollama (local inference fallback)
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=codellama:13b

# GPT-4.1 (set LLM_PROVIDER=openai and LLM_MODEL=gpt-4.1)
# GPT4_API_KEY=sk-...                # Use OPENAI_API_KEY unless separate key needed

# ---------------------------------------------------------------------------
# Embedding Provider Configuration
# ---------------------------------------------------------------------------
# Default provider: openai | bge | nomic
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSIONS=3072            # Must match pgvector column dimension

# OpenAI embeddings (reuses OPENAI_API_KEY above)
OPENAI_EMBEDDING_BASE_URL=https://api.openai.com/v1

# BAAI/BGE embeddings (local via HuggingFace)
BGE_ENABLED=false
BGE_MODEL_NAME=BAAI/bge-large-en-v1.5
BGE_DEVICE=cpu                       # cpu | cuda | mps

# Nomic Embed (local via HuggingFace or Nomic API)
NOMIC_ENABLED=false
NOMIC_MODEL_NAME=nomic-embed-text-v1.5
NOMIC_API_KEY=                       # Required only for Nomic cloud API
NOMIC_DEVICE=cpu

# ---------------------------------------------------------------------------
# Sandbox (Docker-in-Docker / isolated execution)
# ---------------------------------------------------------------------------
SANDBOX_ENABLED=true
SANDBOX_IMAGE=cartographer-sandbox:latest
SANDBOX_DOCKER_SOCKET=/var/run/docker.sock
SANDBOX_WORKSPACE_BASE=/tmp/cartographer/sandbox
SANDBOX_MAX_CONCURRENT=5
SANDBOX_TIMEOUT_SECONDS=300
SANDBOX_MEMORY_LIMIT=2g
SANDBOX_CPU_LIMIT=2
# Windows/WSL2: use host-path mapping via Docker Desktop named volume
SANDBOX_WINDOWS_WSL2=false           # Set true when running on Windows+Docker Desktop

# ---------------------------------------------------------------------------
# Ingestion
# ---------------------------------------------------------------------------
INGESTION_CHUNK_SIZE=1500            # Characters per chunk
INGESTION_CHUNK_OVERLAP=200
INGESTION_MAX_FILE_SIZE_MB=5         # Skip files larger than this
INGESTION_SUPPORTED_EXTENSIONS=.py,.ts,.js,.tsx,.jsx,.java,.go,.rs,.cpp,.c,.h,.md,.yaml,.yml,.json,.toml

# ---------------------------------------------------------------------------
# Retrieval / RAG
# ---------------------------------------------------------------------------
RETRIEVAL_TOP_K_VECTOR=20
RETRIEVAL_TOP_K_KEYWORD=10
RETRIEVAL_TOP_K_GRAPH=15
RETRIEVAL_TOP_K_FINAL=10             # After re-ranking
RETRIEVAL_GRAPH_TRAVERSAL_DEPTH=3
RETRIEVAL_RERANKER_ENABLED=true
RETRIEVAL_CONTEXT_COMPRESSION=true

# ---------------------------------------------------------------------------
# Observability
# ---------------------------------------------------------------------------
OTEL_ENABLED=false
OTEL_SERVICE_NAME=cartographer-backend
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_TRACES_SAMPLER=always_on

PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

LOG_LEVEL=INFO                       # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json                      # json | console

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_ALLOW_CREDENTIALS=true

# ---------------------------------------------------------------------------
# Frontend (filled by Vite at build time)
# ---------------------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_BASE_URL=ws://localhost:8000
VITE_APP_NAME=Cartographer
VITE_GITHUB_OAUTH_ENABLED=false
